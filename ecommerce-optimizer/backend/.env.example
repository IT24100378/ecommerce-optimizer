DATABASE_URL="postgresql://postgres:12345@localhost:5432/ecommerce_db?schema=public"
PORT=5000
AI_SERVICE_URL=http://127.0.0.1:8000/predict
AI_SERVICE_API_KEY=change-me-in-dev
# Auto-start ai_service when backend boots
AI_AUTOSTART_ENABLED=true
AI_AUTOSTART_STRICT=false
AI_AUTOSTART_TIMEOUT_MS=12000
# Optional overrides (leave blank to use defaults)
# AI_SERVICE_DIR=..\\ai_service
# AI_SERVICE_PYTHON=..\\ai_service\\venv\\Scripts\\python.exe
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000

# Default admin bootstrap (password can be changed after login)
ADMIN_EMAIL=admin@ecommerce.local
ADMIN_DEFAULT_PASSWORD=Admin@12345

# true = reset ADMIN_EMAIL password to ADMIN_DEFAULT_PASSWORD on each startup
FORCE_ADMIN_RESET_ON_STARTUP=true
